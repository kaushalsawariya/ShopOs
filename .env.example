# ============================================================
# Shop Accounts Management System — .env
# Copy this to .env and fill in your keys
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- LangSmith (optional but recommended for tracing) ---
# Get key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=shop-accounts-capstone

# --- Database ---
DATABASE_URL=sqlite:///./data/shop_accounts.db

# --- Vector Store path (for RAG) ---
VECTOR_STORE_PATH=./data/vector_store

# --- Guardrails ---
MAX_INPUT_LENGTH=2000
BLOCKED_SQL_KEYWORDS=DROP,DELETE,TRUNCATE,ALTER,CREATE,INSERT,UPDATE,EXEC,GRANT,REVOKE
